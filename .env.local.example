# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must never be committed.

# ---------------------------------------------------------------------------
# Mock data (set to true to run without any Azure or Firebase credentials)
# ---------------------------------------------------------------------------
VITE_USE_MOCK_DATA=true

# ---------------------------------------------------------------------------
# Azure DevOps (required when VITE_USE_MOCK_DATA=false)
#
# Create a Personal Access Token at:
#   https://dev.azure.com/<your-org>/_usersSettings/tokens
# Scope: Build → Read (nothing else needed)
# ---------------------------------------------------------------------------
VITE_AZURE_DEVOPS_PAT=
VITE_AZURE_DEVOPS_ORG=
VITE_AZURE_DEVOPS_PROJECT=

# ---------------------------------------------------------------------------
# Firebase / Firestore (optional — enables persistent manual graph nodes)
#
# Without these vars the app still works; manual nodes survive only for the
# current browser session (stored in component state, not persisted).
#
# Setup steps:
#   1. Go to https://console.firebase.google.com and create a new project.
#   2. In the project console, click "Add app" → Web and register the app.
#      Copy the firebaseConfig values into the variables below.
#   3. In the left sidebar go to Build → Firestore Database.
#      Click "Create database" and choose a region close to your users.
#      Start in production mode (locked rules).
#   4. Open the "Rules" tab and replace the default rules with:
#
#        rules_version = '2';
#        service cloud.firestore {
#          match /databases/{database}/documents {
#            match /graphs/{clientId} {
#              allow read, write: if true;
#            }
#          }
#        }
#
#      This app has no Firebase Auth layer, so rules must allow unauthenticated
#      access. The rule above restricts open access to the "graphs" collection
#      only (everything else stays locked). Deploy on a private/internal network
#      to limit exposure — the same tradeoff already accepted for the Azure PAT.
#
# The Firebase API key below is a public client identifier (not a secret);
# access control is enforced entirely by Firestore Security Rules.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
